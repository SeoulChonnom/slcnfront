  "components": {
    "schemas": {
      "ScheduleUdo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "스케쥴 ID"
          },
          "calendarId": {
            "type": "string",
            "description": "캘린더 ID",
            "example": "cal1"
          },
          "title": {
            "type": "string",
            "description": "제목",
            "example": "title"
          },
          "body": {
            "type": "string",
            "description": "설명",
            "example": "body"
          },
          "start": {
            "type": "string",
            "description": "시작 일시(ISO 8601, 종일 일정은 yyyy-MM-dd)",
            "example": "2025-03-01T00:00:00+09:00"
          },
          "end": {
            "type": "string",
            "description": "종료 일시(ISO 8601, 종일 일정은 yyyy-MM-dd)",
            "example": "2025-03-01T01:00:00+09:00"
          },
          "allDay": {
            "type": "boolean",
            "description": "종일 일정 여부",
            "example": false
          },
          "location": {
            "type": "string",
            "description": "장소",
            "example": "location"
          }
        }
      },
      "ScheduleRdo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "calendarId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "start": {
            "type": "string"
          },
          "end": {
            "type": "string"
          },
          "allDay": {
            "type": "boolean"
          },
          "location": {
            "type": "string"
          }
        }
      },
      "CalendarUdo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "캘린더 ID",
            "example": "CALENDAR-0001"
          },
          "name": {
            "type": "string",
            "description": "캘린더 이름",
            "example": "아영"
          },
          "backgroundColor": {
            "type": "string",
            "description": "배경 색상",
            "example": "#FE9FC8"
          },
          "borderColor": {
            "type": "string",
            "description": "테두리 색상",
            "example": "#FE9FC8"
          },
          "textColor": {
            "type": "string",
            "description": "텍스트 색상",
            "example": "#111111"
          },
          "editable": {
            "type": "boolean",
            "description": "편집 가능 여부",
            "example": true
          },
          "startEditable": {
            "type": "boolean",
            "description": "시작 시각 수정 가능 여부",
            "example": true
          },
          "durationEditable": {
            "type": "boolean",
            "description": "기간 수정 가능 여부",
            "example": true
          },
          "defaultSelected": {
            "type": "boolean",
            "description": "기본 선택 여부",
            "example": true
          },
          "sortOrder": {
            "type": "integer",
            "format": "int32",
            "description": "정렬 순서",
            "example": 1
          }
        }
      },
      "CalendarRdo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "backgroundColor": {
            "type": "string"
          },
          "borderColor": {
            "type": "string"
          },
          "textColor": {
            "type": "string"
          },
          "visible": {
            "type": "boolean"
          },
          "editable": {
            "type": "boolean"
          },
          "startEditable": {
            "type": "boolean"
          },
          "durationEditable": {
            "type": "boolean"
          },
          "defaultSelected": {
            "type": "boolean"
          },
          "sortOrder": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "UserRdo": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "roleList": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["USER", "ADMIN"]
            }
          }
        }
      },
      "UserCdo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "UserLoginCdo": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "TripCdo": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "type": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(ryu|ayo)$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "logo": {
            "type": "string",
            "minLength": 1
          },
          "firstMap": {
            "type": "string",
            "minLength": 1
          },
          "secondMap": {
            "type": "string"
          },
          "nextButtonText": {
            "type": "string"
          },
          "previousButtonText": {
            "type": "string"
          },
          "driveUrl": {
            "type": "string",
            "minLength": 1
